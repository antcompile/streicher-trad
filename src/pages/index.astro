---
// Root redirect — detect language preference, fall back to English
---

<html>
<head>
  <meta charset="utf-8" />
  <meta http-equiv="refresh" content="0;url=/en/" />
  <title>Redirecting…</title>
  <script is:inline>
    (function() {
      var stored = localStorage.getItem('danysbees-lang');
      var lang = stored || (navigator.language || '').split('-')[0];
      var supported = ['en', 'ar', 'fr'];
      if (supported.indexOf(lang) !== -1) {
        window.location.replace('/' + lang + '/');
      } else {
        window.location.replace('/en/');
      }
    })();
  </script>
</head>
<body>
  <p>Redirecting to <a href="/en/">/en/</a>…</p>
</body>
</html>
