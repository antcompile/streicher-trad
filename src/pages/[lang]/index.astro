---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import SEO from '../../components/SEO.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import TrustBadge from '../../components/TrustBadge.astro';
import ProductCard from '../../components/ProductCard.astro';
import BlogCard from '../../components/BlogCard.astro';
import TestimonialCard from '../../components/TestimonialCard.astro';
import NewsletterForm from '../../components/NewsletterForm.astro';
import { supportedLangs, type Lang } from '../../i18n/languages';
import { useTranslation, getLocalizedContent } from '../../i18n/utils';
import { getCollection } from 'astro:content';
import { siteConfig } from '../../data/siteConfig';

export function getStaticPaths() {
  return supportedLangs.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Lang };
const t = useTranslation(lang);
const currentPath = `/${lang}/`;

const allProducts = await getCollection('products');
const featuredProducts = allProducts.filter((p) =>
  ['thyme', 'wildflower', 'oak'].includes(p.data.id)
);
const allTestimonials = await getCollection('testimonials');
const testimonials = allTestimonials.slice(0, 3);
const allPosts = await getCollection('blog');
const latestPosts = allPosts.sort((a, b) =>
  new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
).slice(0, 3);

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: "Dany's Bees",
  description: t('hero.subtitle'),
  url: siteConfig.url,
  telephone: siteConfig.phone,
  email: siteConfig.email,
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Barhalioun',
    addressRegion: 'North Lebanon',
    addressCountry: 'LB',
  },
};
---

<BaseLayout lang={lang} title={`${t('hero.title')} | Dany's Bees`}>
  <Fragment slot="head">
    <SEO
      title={t('hero.title')}
      description={t('hero.subtitle')}
      lang={lang}
      slug=""
      jsonLd={jsonLd}
    />
  </Fragment>

  <Header lang={lang} currentPath={currentPath} transparent />

  <main id="main-content">
    <!-- Hero -->
    <section class="relative min-h-screen flex items-center justify-center overflow-hidden honeycomb-bg">
      <div class="absolute inset-0 z-0">
        <img
          src="/images/hero/mountains.jpg"
          alt={t('hero.subtitle')}
          class="w-full h-full object-cover"
        />
        <div class="absolute inset-0 bg-dark/35"></div>
      </div>

      <div class="relative z-10 text-center px-4 max-w-4xl">
        <h1 class="font-serif text-4xl sm:text-5xl md:text-7xl text-white mb-8 leading-tight tracking-tight">
          {t('hero.title')}
        </h1>
        <p class="text-xl md:text-2xl text-white/80 mb-10 max-w-2xl mx-auto leading-relaxed">
          {t('hero.subtitle')}
        </p>
        <div class="flex flex-col sm:flex-row gap-6 justify-center items-center">
          <a
            href={`/${lang}/products/`}
            class="honey-gradient text-white px-10 py-4 rounded-xl text-lg font-medium shadow-xl hover:scale-105 transition-transform"
          >
            {t('hero.cta_shop')}
          </a>
          <a
            href={`/${lang}/tours/`}
            class="bg-white/10 backdrop-blur-md border border-white/30 text-white px-10 py-4 rounded-xl text-lg font-medium hover:bg-white/20 transition-all"
          >
            {t('hero.cta_tour')}
          </a>
        </div>
      </div>

      <!-- Scroll indicator -->
      <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce" aria-hidden="true">
        <svg class="w-6 h-6 text-white/60" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
        </svg>
      </div>
    </section>

    <!-- Header scroll sentinel -->
    <div id="header-sentinel" class="h-1" aria-hidden="true"></div>

    <!-- Trust Strip -->
    <section className="bg-surface-container-high py-12">
    <div className="max-w-7xl mx-auto px-6 md:px-8">
      <div className="grid grid-cols-2 md:grid-cols-4 gap-6 md:gap-8">

        {[
          {
            text: t('trust.raw'),
            icon: (
              <svg className="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" strokeWidth="1.5">
                <path strokeLinecap="round" strokeLinejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            )
          },
          {
            text: t('trust.family'),
            icon: (
              <svg className="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" strokeWidth="1.5">
                <path strokeLinecap="round" strokeLinejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            )
          },
          {
            text: t('trust.terroir'),
            icon: (
              <svg className="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" strokeWidth="1.5">
                <path strokeLinecap="round" strokeLinejoin="round" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21" />
              </svg>
            )
          },
          {
            text: t('trust.spoon'),
            icon: (
              <svg className="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" strokeWidth="1.5">
                <path strokeLinecap="round" strokeLinejoin="round" d="M21 11.25v8.25a1.5 1.5 0 01-1.5 1.5H5.25a1.5 1.5 0 01-1.5-1.5v-8.25M12 4.875A2.625 2.625 0 109.375 7.5H12m0-2.625V7.5m0-2.625A2.625 2.625 0 1114.625 7.5H12m0 0V21" />
              </svg>
            )
          }
        ].map((item, i) => (
          <div key={i} className="flex flex-col items-center text-center">

            {/* HEXAGON */}
            <div
              className="
                w-20
                aspect-[1/1.1547]
                flex items-center justify-center
                text-white
                shadow-md
                transition-transform duration-300
                hover:scale-105
              "
              style={{
                clipPath: 'polygon(25% 6.7%, 75% 6.7%, 100% 50%, 75% 93.3%, 25% 93.3%, 0% 50%)',
                background: 'linear-gradient(135deg, #a16207, #854d0e)'
              }}
            >
              {item.icon}
            </div>

            {/* TEXT */}
            <p className="mt-4 text-sm md:text-base font-medium text-gray-800">
              {item.text}
            </p>
          </div>
        ))}

      </div>
    </div>
</section>

    <!-- Product Highlights -->
    <section class="py-24 bg-surface">
      <div class="max-w-7xl mx-auto px-6 md:px-8">
        <div class="flex flex-col md:flex-row justify-between items-end mb-16 gap-8">
          <div class="max-w-xl">
            <h2 class="font-serif text-4xl md:text-5xl text-primary mb-4 italic">{t('products.heading')}</h2>
            <p class="text-on-surface-variant text-lg">{t('products.subtitle')}</p>
          </div>
          <a class="text-primary font-medium flex items-center gap-2 group flex-shrink-0" href={`/${lang}/products/`}>
            {t('products.view_all')}
            <svg class="w-4 h-4 transition-transform group-hover:translate-x-1 rtl:group-hover:-translate-x-1 rtl:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
            </svg>
          </a>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-12">
          {featuredProducts.map((product) => (
            <ProductCard product={product} lang={lang} />
          ))}
        </div>
      </div>
    </section>

    <!-- Story Teaser -->
    <section class="py-24 bg-surface-container-low overflow-hidden">
      <div class="max-w-7xl mx-auto px-6 md:px-8 grid grid-cols-1 md:grid-cols-2 gap-12 md:gap-16 items-center">
        <div class="relative order-2 md:order-1">
          <div class="absolute -top-12 -start-12 w-48 h-48 bg-secondary-container opacity-30 hexagon-mask z-0" aria-hidden="true"></div>
          <img
            src="/images/about/beekeeper.jpg"
            alt={t('story_teaser.heading')}
            loading="lazy"
            class="relative z-10 w-full rounded-2xl shadow-2xl"
          />
        </div>
        <div class="order-1 md:order-2 space-y-8">
          <span class="text-secondary font-medium tracking-widest uppercase text-sm">{t('story_teaser.label')}</span>
          <h2 class="font-serif text-3xl md:text-5xl text-primary leading-tight">
            {t('story_teaser.heading')}
          </h2>
          <p class="text-on-surface-variant text-lg leading-relaxed">
            {t('story_teaser.text')}
          </p>
          <a class="text-primary-container font-bold border-b-2 border-primary-container pb-1 inline-block hover:opacity-80 transition-opacity" href={`/${lang}/about/`}>
            {t('story_teaser.cta')}
          </a>
        </div>
      </div>
    </section>

    <!-- Tour Teaser -->
    <section class="py-24 bg-surface">
      <div class="max-w-7xl mx-auto px-6 md:px-8">
        <SectionHeading title={t('tours.heading')} subtitle={t('tours.subtitle')} />

        <div class="grid grid-cols-1 md:grid-cols-4 gap-4 md:gap-6 mb-12" style="min-height: 400px;">
          <div class="md:col-span-2 md:row-span-2 rounded-2xl overflow-hidden relative">
            <img src="/images/tours/gallery-1.jpg" alt="" loading="lazy" class="w-full h-full object-cover hover:scale-105 transition-transform duration-1000" />
          </div>
          <div class="rounded-2xl overflow-hidden relative aspect-[4/3] md:aspect-auto">
            <img src="/images/tours/gallery-2.jpg" alt="" loading="lazy" class="w-full h-full object-cover" />
          </div>
          <div class="rounded-2xl overflow-hidden relative aspect-[4/3] md:aspect-auto">
            <img src="/images/tours/gallery-3.jpg" alt="" loading="lazy" class="w-full h-full object-cover" />
          </div>
          <div class="md:col-span-2 rounded-2xl overflow-hidden relative aspect-[2/1] md:aspect-auto">
            <img src="/images/tours/gallery-4.jpg" alt="" loading="lazy" class="w-full h-full object-cover" />
          </div>
        </div>

        <div class="text-center">
          <a href={`/${lang}/tours/`} class="honey-gradient text-white px-12 py-4 rounded-xl font-medium shadow-lg hover:scale-105 transition-transform inline-block">
            {t('tours.explore')}
          </a>
        </div>
      </div>
    </section>

    <!-- Blog Teaser -->
    <section class="py-24 bg-surface-container-low">
      <div class="max-w-7xl mx-auto px-6 md:px-8">
        <SectionHeading title={t('blog.heading')} subtitle={t('blog.subtitle')} />
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-12">
          {latestPosts.map((post) => (
            <BlogCard post={post} lang={lang} />
          ))}
        </div>
      </div>
    </section>

    <!-- Testimonials -->
    <section class="py-24 bg-surface">
      <div class="max-w-7xl mx-auto px-6 md:px-8">
        <SectionHeading title={t('testimonials.heading')} />
        <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
          {testimonials.map((testimonial) => (
            <TestimonialCard testimonial={testimonial} lang={lang} />
          ))}
        </div>
      </div>
    </section>

    <!-- Newsletter -->
    <NewsletterForm lang={lang} />
  </main>

  <Footer lang={lang} />
</BaseLayout>
