---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import SEO from '../../../components/SEO.astro';
import WhatsAppButton from '../../../components/WhatsAppButton.astro';
import ProductCard from '../../../components/ProductCard.astro';
import { supportedLangs, type Lang } from '../../../i18n/languages';
import { useTranslation, getLocalizedContent } from '../../../i18n/utils';
import { getCollection } from 'astro:content';
import { siteConfig } from '../../../data/siteConfig';

export async function getStaticPaths() {
  const products = await getCollection('products');
  const paths = [];
  for (const lang of supportedLangs) {
    for (const product of products) {
      paths.push({
        params: { lang, slug: product.id },
        props: { product },
      });
    }
  }
  return paths;
}

const { lang, slug } = Astro.params as { lang: Lang; slug: string };
const { product } = Astro.props;
const t = useTranslation(lang);
const currentPath = `/${lang}/products/${slug}/`;
const d = product.data;

const name = getLocalizedContent(d.name, lang);
const description = getLocalizedContent(d.description, lang);
const notes = getLocalizedContent(d.tasting_notes, lang);
const flora = getLocalizedContent(d.flora_source, lang);

const allProducts = await getCollection('products');
const related = allProducts.filter((p) => p.id !== product.id).slice(0, 3);

const seasonLabels: Record<string, Record<string, string>> = {
  'spring': { en: 'Spring', ar: 'الربيع', fr: 'Printemps' },
  'summer': { en: 'Summer', ar: 'الصيف', fr: 'Été' },
  'autumn': { en: 'Autumn', ar: 'الخريف', fr: 'Automne' },
  'spring-summer': { en: 'Spring–Summer', ar: 'الربيع–الصيف', fr: 'Printemps–Été' },
  'year-round': { en: 'Year-round', ar: 'على مدار السنة', fr: 'Toute l\'année' },
};
const seasonText = seasonLabels[d.season]?.[lang] || d.season;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name,
  description,
  image: `${siteConfig.url}${d.image}`,
  offers: {
    '@type': 'Offer',
    price: d.price_usd,
    priceCurrency: 'USD',
    availability: d.in_stock ? 'https://schema.org/InStock' : 'https://schema.org/OutOfStock',
  },
};
---

<BaseLayout lang={lang} title={`${name} | Dany's Bees`}>
  <Fragment slot="head">
    <SEO
      title={name}
      description={notes}
      image={d.image}
      lang={lang}
      slug={`products/${slug}/`}
      type="product"
      jsonLd={jsonLd}
    />
  </Fragment>

  <Header lang={lang} currentPath={currentPath} />

  <main id="main-content" class="pt-32 pb-20 max-w-7xl mx-auto px-6 md:px-8">
    <!-- Back link -->
    <a href={`/${lang}/products/`} class="inline-flex items-center gap-2 text-primary font-medium mb-8 hover:opacity-80 transition-opacity">
      <svg class="w-4 h-4 rtl:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
      </svg>
      {t('common.back')}
    </a>

    <!-- Product Detail -->
    <section class="grid grid-cols-1 lg:grid-cols-2 gap-12 md:gap-16 items-start mb-24">
      <div class="relative">
        <div class="bg-surface-container-low rounded-xl overflow-hidden aspect-[4/5] shadow-sm">
          <img src={d.image} alt={name} class="w-full h-full object-cover" />
        </div>
        <div class="absolute -bottom-6 -start-6 w-32 h-32 bg-secondary-container/20 rounded-full blur-3xl -z-10" aria-hidden="true"></div>
      </div>

      <div class="flex flex-col space-y-8">
        <div class="space-y-4">
          {d.badge && (
            <span class="bg-secondary-container text-olive px-4 py-1 rounded-full text-xs font-medium tracking-widest uppercase">
              {d.badge === 'most-popular' ? (lang === 'ar' ? 'الأكثر شعبية' : lang === 'fr' ? 'Le Plus Populaire' : 'Most Popular') : d.badge === 'raw-comb' ? (lang === 'ar' ? 'شمع خام' : lang === 'fr' ? 'Rayon Brut' : 'Raw Comb') : d.badge}
            </span>
          )}
          <h1 class="text-4xl md:text-6xl font-serif font-bold text-primary leading-tight">{name}</h1>
          <p class="text-3xl font-serif text-on-surface-variant">
            <span dir="ltr">${d.price_usd}</span>
            <span class="text-lg font-sans font-normal opacity-60">/ {d.weight_kg}kg</span>
          </p>
        </div>

        <div class="grid grid-cols-2 gap-8 py-8 border-y border-outline-variant/20">
          <div class="space-y-1">
            <span class="text-xs font-bold uppercase tracking-widest text-secondary">{t('products.flora_source')}</span>
            <p class="font-serif text-lg italic">{flora}</p>
          </div>
          <div class="space-y-1">
            <span class="text-xs font-bold uppercase tracking-widest text-secondary">{t('products.season')}</span>
            <p class="font-serif text-lg italic">{seasonText}</p>
          </div>
          <div class="col-span-2 space-y-1">
            <span class="text-xs font-bold uppercase tracking-widest text-secondary">{t('products.tasting_notes')}</span>
            <p class="font-serif text-lg italic">{notes}</p>
          </div>
        </div>

        {d.includes_spoon && (
          <div class="bg-surface-container-low p-6 rounded-xl border border-outline-variant/10 flex items-center gap-4">
            <div class="w-12 h-12 flex items-center justify-center bg-primary-container/20 text-primary rounded-full flex-shrink-0">
              <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21 11.25v8.25a1.5 1.5 0 01-1.5 1.5H5.25a1.5 1.5 0 01-1.5-1.5v-8.25M12 4.875A2.625 2.625 0 109.375 7.5H12m0-2.625V7.5m0-2.625A2.625 2.625 0 1114.625 7.5H12m0 0V21" />
              </svg>
            </div>
            <p class="text-on-surface-variant italic">{t('products.includes_spoon')}</p>
          </div>
        )}

        <div class="space-y-4 pt-4">
          <WhatsAppButton productName={name} lang={lang} size="lg" fullWidth />
          <p class="text-center text-sm text-on-surface-variant">
            {t('common.or_call')}
            <a href={`tel:${siteConfig.phoneRaw}`} class="text-primary font-medium hover:underline ms-1" dir="ltr">{siteConfig.phone}</a>
          </p>
        </div>
      </div>
    </section>

    <!-- Description -->
    <section class="max-w-4xl mx-auto mb-24">
      <div class="text-lg leading-relaxed text-on-surface-variant">
        <p>{description}</p>
      </div>
    </section>

    <!-- Related Products -->
    <section class="mt-16">
      <div class="flex justify-between items-end mb-12">
        <div>
          <span class="text-secondary font-medium tracking-widest uppercase text-sm">{t('products.you_might_like')}</span>
          <h3 class="text-3xl md:text-4xl font-serif font-bold text-primary mt-2">{t('products.you_might_like')}</h3>
        </div>
        <a class="text-primary font-medium hover:underline flex items-center gap-1" href={`/${lang}/products/`}>
          {t('products.view_all')}
          <svg class="w-4 h-4 rtl:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </a>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {related.map((p) => (
          <ProductCard product={p} lang={lang} />
        ))}
      </div>
    </section>
  </main>

  <Footer lang={lang} />
</BaseLayout>
