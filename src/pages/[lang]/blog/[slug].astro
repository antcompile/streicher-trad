---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import SEO from '../../../components/SEO.astro';
import BlogCard from '../../../components/BlogCard.astro';
import { supportedLangs, type Lang } from '../../../i18n/languages';
import { useTranslation, getLocalizedContent } from '../../../i18n/utils';
import { getCollection, render } from 'astro:content';
import { siteConfig } from '../../../data/siteConfig';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  const paths = [];
  for (const lang of supportedLangs) {
    for (const post of posts) {
      paths.push({
        params: { lang, slug: post.id },
        props: { post },
      });
    }
  }
  return paths;
}

const { lang, slug } = Astro.params as { lang: Lang; slug: string };
const { post } = Astro.props;
const t = useTranslation(lang);
const currentPath = `/${lang}/blog/${slug}/`;

const title = getLocalizedContent(post.data.title, lang);
const description = getLocalizedContent(post.data.description, lang);
const { Content } = await render(post);

const date = new Date(post.data.date).toLocaleDateString(
  lang === 'fr' ? 'fr-FR' : 'en-US',
  { year: 'numeric', month: 'long', day: 'numeric' }
);

const categoryLabels: Record<string, string> = {
  prevoyance: t('expertises.prevoyance_title'),
  epargne: t('expertises.epargne_title'),
  retraite: t('expertises.retraite_title'),
  patrimoine: t('expertises.patrimoine_title'),
  fiscalite: lang === 'fr' ? 'Fiscalite' : 'Tax',
};
const categoryLabel = categoryLabels[post.data.category] || post.data.category;

// Estimate read time (~200 words/min for French)
const wordCount = post.body?.split(/\s+/).length || 300;
const readTime = Math.max(3, Math.ceil(wordCount / 200));

const allPosts = await getCollection('blog');
const related = allPosts
  .filter((p) => p.id !== post.id)
  .sort((a, b) => {
    // Prefer same category
    const aMatch = a.data.category === post.data.category ? 1 : 0;
    const bMatch = b.data.category === post.data.category ? 1 : 0;
    return bMatch - aMatch;
  })
  .slice(0, 2);

const linkedInShareUrl = `https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(`${siteConfig.url}/${lang}/blog/${slug}/`)}`;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description,
  datePublished: post.data.date,
  author: {
    '@type': 'Person',
    name: post.data.author,
  },
  publisher: {
    '@type': 'Organization',
    name: 'Streicher Trad',
    url: siteConfig.url,
  },
};
---

<BaseLayout lang={lang} title={`${title} | Streicher Trad`}>
  <Fragment slot="head">
    <SEO
      title={title}
      description={description}
      lang={lang}
      slug={`blog/${slug}/`}
      type="article"
      jsonLd={jsonLd}
    />
  </Fragment>

  <Header lang={lang} currentPath={currentPath} />

  <main id="main-content" class="pt-32 pb-20">
    <article class="max-w-3xl mx-auto px-6 md:px-8">
      <!-- Back link -->
      <a href={`/${lang}/blog/`} class="inline-flex items-center gap-2 text-primary font-medium mb-8 hover:opacity-80 transition-opacity">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
        </svg>
        {t('common.back')}
      </a>

      <!-- Article header -->
      <header class="mb-12">
        <div class="flex flex-wrap items-center gap-3 mb-6">
          <span class="inline-block bg-primary-container/15 text-primary px-3 py-1 rounded-full text-xs font-bold uppercase tracking-wider">
            {categoryLabel}
          </span>
          <span class="text-sm text-muted">
            <time datetime={post.data.date}>{date}</time>
          </span>
          <span class="w-1 h-1 bg-outline-variant rounded-full" aria-hidden="true"></span>
          <span class="text-sm text-muted">{readTime} {t('blog.read_time')}</span>
        </div>

        <h1 class="font-headline font-black text-3xl md:text-5xl text-dark leading-tight tracking-tighter mb-6">
          {title}
        </h1>

        <div class="flex items-center gap-3 text-sm text-muted">
          <span>{t('blog.by')} {post.data.author}</span>
        </div>
      </header>

      <!-- Content -->
      <div class="prose">
        <Content />
      </div>

      <!-- Tags -->
      <div class="mt-10 flex flex-wrap gap-2">
        {post.data.tags.map((tag: string) => (
          <span class="bg-surface-container-low text-on-surface-variant px-3 py-1 rounded-full text-xs font-medium">
            {tag}
          </span>
        ))}
      </div>

      <!-- Share -->
      <div class="mt-12 pt-8 border-t border-outline-variant/15 flex items-center gap-4">
        <span class="text-sm text-muted font-medium">{t('common.share')}:</span>

        <!-- LinkedIn -->
        <a
          href={linkedInShareUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 text-sm text-primary hover:underline"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
          </svg>
          LinkedIn
        </a>

        <!-- Copy link -->
        <button
          class="inline-flex items-center gap-2 text-sm text-primary hover:underline"
          id="copy-link-btn"
          data-url={`${siteConfig.url}/${lang}/blog/${slug}/`}
        >
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 011.242 7.244l-4.5 4.5a4.5 4.5 0 01-6.364-6.364l1.757-1.757m9.86-2.04a4.5 4.5 0 00-1.242-7.244l-4.5-4.5a4.5 4.5 0 00-6.364 6.364L4.5 8.06" />
          </svg>
          <span id="copy-link-text">{lang === 'fr' ? 'Copier le lien' : 'Copy link'}</span>
        </button>
      </div>
    </article>

    <!-- Related Posts -->
    {related.length > 0 && (
      <section class="max-w-7xl mx-auto px-6 md:px-8 mt-24 pt-16 border-t border-outline-variant/10">
        <h2 class="font-headline font-black text-3xl text-dark tracking-tighter mb-12">
          {t('common.related_articles')}
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          {related.map((p) => (
            <BlogCard post={p} lang={lang} />
          ))}
        </div>
      </section>
    )}
  </main>

  <Footer lang={lang} />
</BaseLayout>

<script>
  const btn = document.getElementById('copy-link-btn');
  const text = document.getElementById('copy-link-text');
  btn?.addEventListener('click', async () => {
    const url = (btn as HTMLElement).dataset.url || '';
    try {
      await navigator.clipboard.writeText(url);
      if (text) text.textContent = 'Copie !';
      setTimeout(() => {
        if (text) text.textContent = text.dataset.original || 'Copier le lien';
      }, 2000);
    } catch {}
  });
  if (text) {
    text.dataset.original = text.textContent || '';
  }
</script>
