---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import SEO from '../../../components/SEO.astro';
import BlogCard from '../../../components/BlogCard.astro';
import { supportedLangs, type Lang } from '../../../i18n/languages';
import { useTranslation, getLocalizedContent } from '../../../i18n/utils';
import { getCollection, render } from 'astro:content';
import { siteConfig } from '../../../data/siteConfig';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  const paths = [];
  for (const lang of supportedLangs) {
    for (const post of posts) {
      paths.push({
        params: { lang, slug: post.id },
        props: { post },
      });
    }
  }
  return paths;
}

const { lang, slug } = Astro.params as { lang: Lang; slug: string };
const { post } = Astro.props;
const t = useTranslation(lang);
const currentPath = `/${lang}/blog/${slug}/`;

const title = getLocalizedContent(post.data.title, lang);
const description = getLocalizedContent(post.data.description, lang);
const { Content } = await render(post);

const date = new Date(post.data.date).toLocaleDateString(
  lang === 'ar' ? 'ar-LB' : lang === 'fr' ? 'fr-FR' : 'en-US',
  { year: 'numeric', month: 'long', day: 'numeric' }
);

const allPosts = await getCollection('blog');
const related = allPosts.filter((p) => p.id !== post.id).slice(0, 2);

const whatsappShareUrl = `https://wa.me/?text=${encodeURIComponent(`${title} — ${siteConfig.url}/${lang}/blog/${slug}/`)}`;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description,
  datePublished: post.data.date,
  author: { '@type': 'Person', name: post.data.author },
  image: `${siteConfig.url}${post.data.image}`,
};
---

<BaseLayout lang={lang} title={`${title} | Dany's Bees`}>
  <Fragment slot="head">
    <SEO
      title={title}
      description={description}
      image={post.data.image}
      lang={lang}
      slug={`blog/${slug}/`}
      type="article"
      jsonLd={jsonLd}
    />
  </Fragment>

  <Header lang={lang} currentPath={currentPath} />

  <main id="main-content" class="pt-32 pb-20">
    <article class="max-w-3xl mx-auto px-6 md:px-8">
      <!-- Back -->
      <a href={`/${lang}/blog/`} class="inline-flex items-center gap-2 text-primary font-medium mb-8 hover:opacity-80 transition-opacity">
        <svg class="w-4 h-4 rtl:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
        </svg>
        {t('common.back')}
      </a>

      <!-- Header -->
      <header class="mb-12">
        <div class="flex flex-wrap items-center gap-3 mb-4 text-sm text-muted">
          <time datetime={post.data.date}>{date}</time>
          <span class="w-1 h-1 bg-outline-variant rounded-full" aria-hidden="true"></span>
          <span>{t('blog.by')} {post.data.author}</span>
        </div>
        <h1 class="font-serif text-3xl md:text-5xl text-dark leading-tight mb-6">{title}</h1>
        <div class="flex flex-wrap gap-2">
          {post.data.tags.map((tag: string) => (
            <span class="bg-secondary-container text-olive px-3 py-1 rounded-full text-xs font-medium">{tag}</span>
          ))}
        </div>
      </header>

      <!-- Featured Image -->
      <div class="rounded-xl overflow-hidden mb-12 aspect-[16/9] bg-surface-container-low">
        <img src={post.data.image} alt={title} class="w-full h-full object-cover" />
      </div>

      <!-- Content -->
      <div class="prose">
        <Content />
      </div>

      <!-- Share -->
      <div class="mt-12 pt-8 border-t border-outline-variant/15 flex items-center gap-4">
        <span class="text-sm text-muted font-medium">{t('common.share')}:</span>
        <a href={whatsappShareUrl} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-sm text-primary hover:underline">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          WhatsApp
        </a>
        <button
          class="inline-flex items-center gap-2 text-sm text-primary hover:underline"
          id="copy-link-btn"
          data-url={`${siteConfig.url}/${lang}/blog/${slug}/`}
        >
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 011.242 7.244l-4.5 4.5a4.5 4.5 0 01-6.364-6.364l1.757-1.757m9.86-2.04a4.5 4.5 0 00-1.242-7.244l-4.5-4.5a4.5 4.5 0 00-6.364 6.364L4.5 8.06" /></svg>
          <span id="copy-link-text">{t('common.copy_link')}</span>
        </button>
      </div>
    </article>

    <!-- Related Posts -->
    {related.length > 0 && (
      <section class="max-w-7xl mx-auto px-6 md:px-8 mt-24 pt-16 border-t border-outline-variant/10">
        <h2 class="font-serif text-3xl text-primary mb-12">{t('common.more_from_hive')}</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
          {related.map((p) => (
            <BlogCard post={p} lang={lang} />
          ))}
        </div>
      </section>
    )}
  </main>

  <Footer lang={lang} />
</BaseLayout>

<script>
  const btn = document.getElementById('copy-link-btn');
  const text = document.getElementById('copy-link-text');
  btn?.addEventListener('click', async () => {
    const url = (btn as HTMLElement).dataset.url || '';
    try {
      await navigator.clipboard.writeText(url);
      if (text) text.textContent = text.dataset.copied || 'Copied!';
      setTimeout(() => {
        if (text) text.textContent = text.dataset.original || 'Copy Link';
      }, 2000);
    } catch {}
  });
  if (text) {
    text.dataset.original = text.textContent || '';
    text.dataset.copied = document.documentElement.lang === 'ar' ? 'تم النسخ!' : document.documentElement.lang === 'fr' ? 'Copié !' : 'Copied!';
  }
</script>
