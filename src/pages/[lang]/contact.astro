---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import SEO from '../../components/SEO.astro';
import ContactForm from '../../components/ContactForm.astro';
import { supportedLangs, type Lang } from '../../i18n/languages';
import { useTranslation } from '../../i18n/utils';
import { siteConfig } from '../../data/siteConfig';

export function getStaticPaths() {
  return supportedLangs.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Lang };
const t = useTranslation(lang);
const currentPath = `/${lang}/contact/`;
---

<BaseLayout lang={lang} title={`${t('contact.heading')} | Streicher Trad`}>
  <Fragment slot="head">
    <SEO
      title={t('contact.heading')}
      description={t('contact.subtitle')}
      lang={lang}
      slug="contact/"
    />
  </Fragment>

  <Header lang={lang} currentPath={currentPath} />

  <main id="main-content">
    <!-- Plum gradient header -->
    <header class="relative pt-32 pb-16 plum-gradient overflow-hidden">
      <div class="absolute inset-0 z-0">
        <div class="absolute top-[-10%] right-[-10%] w-[50%] h-[70%] bg-white/5 rounded-full blur-3xl"></div>
      </div>
      <div class="relative z-10 max-w-7xl mx-auto px-6 md:px-8">
        <h1 class="font-headline font-black text-4xl md:text-6xl text-white tracking-tighter mb-4">
          {t('contact.heading')}
        </h1>
        <p class="text-lg text-white/70 max-w-xl">{t('contact.subtitle')}</p>
      </div>
    </header>

    <div id="header-sentinel" class="h-1" aria-hidden="true"></div>

    <!-- Content -->
    <div class="max-w-7xl mx-auto px-6 md:px-8 py-24">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-16">
        <!-- Contact Form (60%) -->
        <div class="lg:col-span-3">
          <h2 class="font-headline font-bold text-2xl text-dark mb-8 tracking-tight">
            {t('contact.heading')}
          </h2>
          <ContactForm lang={lang} />
        </div>

        <!-- Info Sidebar (40%) -->
        <div class="lg:col-span-2 space-y-8">
          <!-- Advisor info -->
          <div class="bg-surface-container-lowest rounded-xl p-8 ghost-border">
            <h3 class="font-headline font-bold text-lg text-dark mb-6">
              {t('contact.info_heading')}
            </h3>

            <div class="space-y-5">
              <!-- Name -->
              <div class="flex items-center gap-4">
                <div class="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center text-primary">
                  <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" />
                  </svg>
                </div>
                <div>
                  <p class="font-bold text-dark">{t('contact.info_name')}</p>
                </div>
              </div>

              <!-- Email -->
              <div class="flex items-center gap-4">
                <div class="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center text-primary">
                  <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
                  </svg>
                </div>
                <a href={`mailto:${siteConfig.email}`} class="text-primary font-medium hover:underline text-sm" dir="ltr">
                  {siteConfig.email}
                </a>
              </div>

              <!-- Phone -->
              <div class="flex items-center gap-4">
                <div class="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center text-primary">
                  <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
                  </svg>
                </div>
                <a href={`tel:${siteConfig.phoneRaw}`} class="text-primary font-medium hover:underline text-sm" dir="ltr">
                  {siteConfig.phone}
                </a>
              </div>
            </div>
          </div>

          <!-- Registration info -->
          <div class="bg-surface-container-lowest rounded-xl p-8 ghost-border">
            <div class="space-y-4 text-sm text-on-surface-variant">
              <div class="flex items-start gap-3">
                <svg class="w-5 h-5 text-primary flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                <span>{t('contact.info_orias')}</span>
              </div>
              <div class="flex items-start gap-3">
                <svg class="w-5 h-5 text-primary flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                <span>{t('contact.info_siret')}</span>
              </div>
            </div>
          </div>

          <!-- Availability note -->
          <div class="bg-primary-fixed/20 rounded-xl p-8">
            <div class="flex items-start gap-3">
              <svg class="w-5 h-5 text-primary flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
              </svg>
              <p class="text-sm text-on-surface-variant leading-relaxed">
                {t('contact.info_available')}
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>

  <Footer lang={lang} />
</BaseLayout>
