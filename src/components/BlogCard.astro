---
import type { Lang } from '../i18n/languages';
import { useTranslation, getLocalizedContent } from '../i18n/utils';

interface Props {
  post: {
    id: string;
    data: {
      title: Record<string, string>;
      date: string;
      author: string;
      description: Record<string, string>;
      category: string;
      tags: string[];
    };
  };
  lang: Lang;
}

const { post, lang } = Astro.props;
const t = useTranslation(lang);
const title = getLocalizedContent(post.data.title, lang);
const description = getLocalizedContent(post.data.description, lang);
const slug = post.id;

const date = new Date(post.data.date).toLocaleDateString(
  lang === 'fr' ? 'fr-FR' : 'en-US',
  { year: 'numeric', month: 'short', day: 'numeric' }
);

const categoryLabels: Record<string, string> = {
  prevoyance: t('expertises.prevoyance_title'),
  epargne: t('expertises.epargne_title'),
  retraite: t('expertises.retraite_title'),
  patrimoine: t('expertises.patrimoine_title'),
  fiscalite: lang === 'fr' ? 'Fiscalite' : 'Tax',
};

const categoryLabel = categoryLabels[post.data.category] || post.data.category;

const readTime = 5;
---

<article class="group bg-surface-container-lowest rounded-2xl overflow-hidden ghost-border transition-shadow hover:shadow-lg">
  <!-- Plum gradient header as placeholder (no photos) -->
  <a href={`/${lang}/blog/${slug}/`} class="block">
    <div class="aspect-[16/9] plum-gradient relative flex items-end p-6">
      <!-- Category pill -->
      <span class="inline-block bg-white/20 text-white text-xs font-bold uppercase tracking-wider px-3 py-1 rounded-full backdrop-blur-sm">
        {categoryLabel}
      </span>
    </div>
  </a>

  <div class="p-6">
    <!-- Date + Read time -->
    <div class="flex items-center gap-3 mb-3 text-xs text-muted font-body">
      <time datetime={post.data.date}>{date}</time>
      <span class="w-1 h-1 bg-outline-variant rounded-full"></span>
      <span>{readTime} {t('blog.read_time')}</span>
    </div>

    <!-- Title -->
    <h3 class="font-headline font-black text-lg md:text-xl text-dark mb-3 leading-snug tracking-tight">
      <a href={`/${lang}/blog/${slug}/`} class="hover:text-primary transition-colors">
        {title}
      </a>
    </h3>

    <!-- Excerpt -->
    <p class="font-body text-on-surface-variant text-sm leading-relaxed mb-4 line-clamp-3">
      {description}
    </p>

    <!-- Read more link -->
    <a
      href={`/${lang}/blog/${slug}/`}
      class="text-primary font-medium text-sm inline-flex items-center gap-1 group/link font-body"
    >
      {t('blog.read_more')}
      <svg class="w-4 h-4 transition-transform group-hover/link:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
      </svg>
    </a>
  </div>
</article>
