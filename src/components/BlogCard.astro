---
import type { Lang } from '../i18n/languages';
import { useTranslation, getLocalizedContent } from '../i18n/utils';

interface Props {
  post: {
    id: string;
    data: {
      title: Record<string, string>;
      date: string;
      author: string;
      description: Record<string, string>;
      image: string;
      tags: string[];
    };
  };
  lang: Lang;
}

const { post, lang } = Astro.props;
const t = useTranslation(lang);
const title = getLocalizedContent(post.data.title, lang);
const description = getLocalizedContent(post.data.description, lang);
const slug = post.id;
const date = new Date(post.data.date).toLocaleDateString(lang === 'ar' ? 'ar-LB' : lang === 'fr' ? 'fr-FR' : 'en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<article class="group">
  <a href={`/${lang}/blog/${slug}/`} class="block">
    <div class="aspect-[4/3] rounded-xl overflow-hidden mb-6 bg-surface-container-low">
      <img
        src={post.data.image}
        alt={title}
        loading="lazy"
        class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
      />
    </div>
  </a>

  <div class="flex items-center gap-3 mb-3 text-sm text-muted">
    <time datetime={post.data.date}>{date}</time>
    <span class="w-1 h-1 bg-outline-variant rounded-full"></span>
    <span>{t('blog.by')} {post.data.author}</span>
  </div>

  <h3 class="font-serif text-xl md:text-2xl text-dark mb-3 leading-snug">
    <a href={`/${lang}/blog/${slug}/`} class="hover:text-primary transition-colors">
      {title}
    </a>
  </h3>

  <p class="text-on-surface-variant text-sm leading-relaxed mb-4 line-clamp-3">
    {description}
  </p>

  <a
    href={`/${lang}/blog/${slug}/`}
    class="text-primary font-medium text-sm inline-flex items-center gap-1 group/link"
  >
    {t('common.read_more')}
    <svg class="w-4 h-4 transition-transform group-hover/link:translate-x-1 rtl:group-hover/link:-translate-x-1 rtl:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
    </svg>
  </a>
</article>
