---
import type { Lang } from '../i18n/languages';
import { useTranslation } from '../i18n/utils';
import { siteConfig } from '../data/siteConfig';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslation(lang);

const expertiseLinks = [
  { label: t('footer.prevoyance'), href: `/${lang}/#expertises` },
  { label: t('footer.epargne'), href: `/${lang}/#expertises` },
  { label: t('footer.retraite'), href: `/${lang}/#expertises` },
  { label: t('footer.patrimoine'), href: `/${lang}/#expertises` },
];

const cabinetLinks = [
  { label: t('footer.approach_link'), href: `/${lang}/#approach` },
  { label: t('footer.legal_link'), href: `/${lang}/legal/` },
  { label: t('footer.privacy_link'), href: `/${lang}/privacy/` },
];

const locationLabel = lang === 'fr' ? siteConfig.location.fr : siteConfig.location.en;
---

<footer class="bg-surface-container-low py-20 px-6 md:px-8">
  <div class="max-w-7xl mx-auto grid grid-cols-1 gap-12 sm:grid-cols-2 lg:grid-cols-4 md:gap-16">
    <!-- Brand -->
    <div class="space-y-4">
      <div class="font-headline font-black text-2xl tracking-tighter text-primary">
        STREICHER TRAD
      </div>
      <p class="text-on-surface-variant text-sm leading-relaxed">
        {t('footer.tagline')}
      </p>
    </div>

    <!-- Expertises -->
    <div>
      <h4 class="font-headline font-bold text-sm uppercase tracking-wide text-dark mb-6">
        {t('footer.expertises_heading')}
      </h4>
      <ul class="space-y-3">
        {expertiseLinks.map((item) => (
          <li>
            <a
              href={item.href}
              class="text-on-surface-variant hover:text-primary transition-colors text-sm"
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </div>

    <!-- Cabinet -->
    <div>
      <h4 class="font-headline font-bold text-sm uppercase tracking-wide text-dark mb-6">
        {t('footer.cabinet_heading')}
      </h4>
      <ul class="space-y-3">
        {cabinetLinks.map((item) => (
          <li>
            <a
              href={item.href}
              class="text-on-surface-variant hover:text-primary transition-colors text-sm"
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </div>

    <!-- Contact -->
    <div>
      <h4 class="font-headline font-bold text-sm uppercase tracking-wide text-dark mb-6">
        {t('footer.contact_heading')}
      </h4>
      <ul class="space-y-4 text-sm">
        <li class="flex items-start gap-3">
          <svg class="w-5 h-5 text-primary flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
          </svg>
          <a href={`tel:${siteConfig.phoneRaw}`} class="text-on-surface-variant hover:text-primary transition-colors">
            {siteConfig.phone}
          </a>
        </li>
        <li class="flex items-start gap-3">
          <svg class="w-5 h-5 text-primary flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
          </svg>
          <a href={`mailto:${siteConfig.email}`} class="text-on-surface-variant hover:text-primary transition-colors">
            {siteConfig.email}
          </a>
        </li>
        <li class="flex items-start gap-3">
          <svg class="w-5 h-5 text-primary flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
          </svg>
          <span class="text-on-surface-variant">{locationLabel}</span>
        </li>
      </ul>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="max-w-7xl mx-auto mt-16 pt-8 border-t border-outline-variant/20 text-on-surface-variant/60 text-xs flex flex-col md:flex-row justify-between items-center gap-4">
    <p>{t('footer.copyright')}</p>
    <div class="flex items-center gap-4">
      <a href={`/${lang}/#newsletter`} class="hover:text-primary transition-colors">{t('footer.newsletter_link')}</a>
      <span aria-hidden="true">|</span>
      <a href={`/${lang}/sitemap/`} class="hover:text-primary transition-colors">{t('footer.sitemap_link')}</a>
    </div>
  </div>
</footer>
