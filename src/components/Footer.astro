---
import type { Lang } from '../i18n/languages';
import { useTranslation } from '../i18n/utils';
import { mainNav } from '../data/navigation';
import { siteConfig } from '../data/siteConfig';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslation(lang);
---

<footer class="bg-inverse-surface text-inverse-on-surface py-20 px-6 md:px-8">
  <div
    class:list={[
      'max-w-7xl mx-auto grid grid-cols-1 gap-12 md:gap-16',
      siteConfig.showInstagram ? 'md:grid-cols-4' : 'md:grid-cols-3',
    ]}
  >
    <!-- Brand -->
    <div class="space-y-6">
      <div class="font-serif italic text-3xl text-primary-fixed-dim">Dany's Bees</div>
      <p class="text-inverse-on-surface/60 text-sm leading-relaxed">
        {t('footer.tagline')}
      </p>
    </div>

    <!-- Quick Links -->
    <div>
      <h4 class="font-bold text-lg mb-8 border-b border-white/10 pb-4">{t('footer.quick_links')}</h4>
      <ul class="space-y-4">
        {mainNav.map((item) => (
          <li>
            <a
              href={item.href(lang)}
              class="text-inverse-on-surface/60 hover:text-primary-fixed-dim transition-colors text-sm"
            >
              {t(item.key)}
            </a>
          </li>
        ))}
      </ul>
    </div>

    <!-- Contact -->
    <div>
      <h4 class="font-bold text-lg mb-8 border-b border-white/10 pb-4">{t('footer.contact_us')}</h4>
      <ul class="space-y-4 text-inverse-on-surface/60 text-sm">
        <li class="flex items-start gap-3">
          <svg class="w-5 h-5 text-primary-fixed-dim flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
          </svg>
          <a href={`tel:${siteConfig.phoneRaw}`} class="hover:text-primary-fixed-dim transition-colors" dir="ltr">
            {siteConfig.phone}
          </a>
        </li>
        <li class="flex items-start gap-3">
          <svg class="w-5 h-5 text-primary-fixed-dim flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
          </svg>
          <a href={`mailto:${siteConfig.email}`} class="hover:text-primary-fixed-dim transition-colors" dir="ltr">
            {siteConfig.email}
          </a>
        </li>
        <li class="flex items-start gap-3">
          <svg class="w-5 h-5 text-primary-fixed-dim flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
          </svg>
          <span>{t('contact.address')}</span>
        </li>
      </ul>
    </div>

    {
      siteConfig.showInstagram && (
        <div>
          <h4 class="font-bold text-lg mb-8 border-b border-white/10 pb-4">{t('footer.follow_us')}</h4>
          <a
            href={siteConfig.instagramUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-3 text-inverse-on-surface/60 hover:text-primary-fixed-dim transition-colors"
          >
            <div class="w-10 h-10 rounded-full bg-white/5 flex items-center justify-center hover:bg-primary transition-colors">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path fill-rule="evenodd" d="M12.315 2c2.43 0 2.784.013 3.808.06 1.064.049 1.791.218 2.427.465a4.902 4.902 0 011.772 1.153 4.902 4.902 0 011.153 1.772c.247.636.416 1.363.465 2.427.048 1.067.06 1.407.06 4.123v.08c0 2.643-.012 2.987-.06 4.043-.049 1.064-.218 1.791-.465 2.427a4.902 4.902 0 01-1.153 1.772 4.902 4.902 0 01-1.772 1.153c-.636.247-1.363.416-2.427.465-1.067.048-1.407.06-4.123.06h-.08c-2.643 0-2.987-.012-4.043-.06-1.064-.049-1.791-.218-2.427-.465a4.902 4.902 0 01-1.772-1.153 4.902 4.902 0 01-1.153-1.772c-.247-.636-.416-1.363-.465-2.427-.047-1.024-.06-1.379-.06-3.808v-.63c0-2.43.013-2.784.06-3.808.049-1.064.218-1.791.465-2.427a4.902 4.902 0 011.153-1.772A4.902 4.902 0 015.45 2.525c.636-.247 1.363-.416 2.427-.465C8.901 2.013 9.256 2 11.685 2h.63zm-.081 1.802h-.468c-2.456 0-2.784.011-3.807.058-.975.045-1.504.207-1.857.344-.467.182-.8.398-1.15.748-.35.35-.566.683-.748 1.15-.137.353-.3.882-.344 1.857-.047 1.023-.058 1.351-.058 3.807v.468c0 2.456.011 2.784.058 3.807.045.975.207 1.504.344 1.857.182.466.399.8.748 1.15.35.35.683.566 1.15.748.353.137.882.3 1.857.344 1.054.048 1.37.058 4.041.058h.08c2.597 0 2.917-.01 3.96-.058.976-.045 1.505-.207 1.858-.344.466-.182.8-.398 1.15-.748.35-.35.566-.683.748-1.15.137-.353.3-.882.344-1.857.048-1.055.058-1.37.058-4.041v-.08c0-2.597-.01-2.917-.058-3.96-.045-.976-.207-1.505-.344-1.858a3.097 3.097 0 00-.748-1.15 3.098 3.098 0 00-1.15-.748c-.353-.137-.882-.3-1.857-.344-1.023-.047-1.351-.058-3.807-.058zM12 6.865a5.135 5.135 0 110 10.27 5.135 5.135 0 010-10.27zm0 1.802a3.333 3.333 0 100 6.666 3.333 3.333 0 000-6.666zm5.338-3.205a1.2 1.2 0 110 2.4 1.2 1.2 0 010-2.4z" clip-rule="evenodd" />
              </svg>
            </div>
            <span class="text-sm">{siteConfig.instagram}</span>
          </a>
        </div>
      )
    }
  </div>

  <div class="max-w-7xl mx-auto mt-16 pt-8 border-t border-white/5 text-inverse-on-surface/40 text-xs flex flex-col md:flex-row justify-between items-center gap-4">
    <p>{t('footer.copyright')}</p>
  </div>
</footer>
