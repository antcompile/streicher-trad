---
import type { Lang } from '../i18n/languages';
import { useTranslation } from '../i18n/utils';
import { mainNav } from '../data/navigation';
import LanguageSwitcher from './LanguageSwitcher.astro';
import MobileNav from './MobileNav.astro';
import { siteConfig } from '../data/siteConfig';

interface Props {
  lang: Lang;
  currentPath: string;
  transparent?: boolean;
}

const { lang, currentPath, transparent = false } = Astro.props;
const t = useTranslation(lang);
---

<div id="header-sentinel" class="absolute top-0 h-1 w-full"></div>

<header
  id="site-header"
  class:list={[
    'fixed top-0 w-full z-50 transition-all duration-300',
    transparent
      ? 'bg-transparent'
      : 'bg-surface/70 backdrop-blur-xl shadow-[0_24px_48px_-12px_rgba(139,26,107,0.08)]',
  ]}
  data-transparent={transparent ? 'true' : 'false'}
>
  <nav class="flex justify-between items-center px-6 md:px-8 py-4 max-w-7xl mx-auto" aria-label="Main navigation">
    <!-- Logo -->
    <a href={`/${lang}/`} class="flex items-center gap-2 flex-shrink-0">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32" fill="none" class="h-8 w-8" aria-hidden="true">
        <rect width="32" height="32" rx="4" fill="#6a0050"/>
        <path d="M18 4 C22 4, 26 7, 26 11 C26 14, 24 16, 20 17 L14 19 C10 20, 8 22, 8 25 C8 28, 11 30, 15 30" stroke="white" stroke-width="4" stroke-linecap="round" fill="none"/>
        <path d="M14 4 C10 4, 6 7, 6 11 C6 13, 7 14.5, 9 15.5" stroke="#c0388c" stroke-width="3.5" stroke-linecap="round" fill="none"/>
        <path d="M23 20 C25 21.5, 26 23, 26 25 C26 28, 22 30, 18 30" stroke="#c0388c" stroke-width="3.5" stroke-linecap="round" fill="none"/>
      </svg>
      <span
        class:list={[
          'font-headline font-black text-2xl tracking-tighter',
          transparent ? 'text-white' : 'text-primary',
        ]}
        id="header-logo-text"
      >
        STREICHER TRAD
      </span>
    </a>

    <!-- Desktop nav links -->
    <div class="hidden lg:flex items-center gap-8">
      {mainNav.map((item) => {
        const href = item.href(lang);
        const isActive = currentPath === href || (href !== `/${lang}/` && currentPath.startsWith(href.replace(/\/$/, '')));
        return (
          <a
            href={href}
            class:list={[
              'font-body text-sm tracking-wide pb-1 transition-colors border-b-2',
              isActive
                ? (transparent ? 'text-white border-white' : 'text-primary border-primary')
                : (transparent ? 'text-white/80 border-transparent hover:text-white' : 'text-muted border-transparent hover:text-primary'),
            ]}
            data-nav-link
          >
            {t(item.key)}
          </a>
        );
      })}
    </div>

    <!-- Right side: phone + language + CTA + hamburger -->
    <div class="flex items-center gap-4">
      <!-- Phone number (lg+ only) -->
      <a
        href={`tel:${siteConfig.phoneRaw}`}
        class:list={[
          'hidden lg:inline-flex items-center gap-2 text-sm font-medium transition-colors',
          transparent ? 'text-white/80 hover:text-white' : 'text-muted hover:text-primary',
        ]}
        id="header-phone"
      >
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
        </svg>
        {siteConfig.phone}
      </a>

      <!-- Language switcher (md+) -->
      <div class:list={['hidden md:block', transparent ? '[&_a]:text-white/80 [&_a]:hover:text-white [&_span]:text-white/40' : '']}>
        <LanguageSwitcher currentLang={lang} currentPath={currentPath} />
      </div>

      <!-- CTA button -->
      <a
        href={`/${lang}/contact/`}
        class="hidden md:inline-flex bg-primary text-white px-5 py-2.5 rounded-md font-medium text-sm hover:opacity-90 transition-opacity items-center gap-2"
      >
        {t('hero.cta_primary')}
      </a>

      <!-- Hamburger (mobile) -->
      <button
        id="mobile-nav-open"
        class="lg:hidden p-2 rounded-lg transition-colors hover:bg-surface-container-low"
        aria-label="Open navigation menu"
      >
        <svg
          class:list={['w-6 h-6', transparent ? 'text-white' : 'text-dark']}
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
          id="hamburger-icon"
        >
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
        </svg>
      </button>
    </div>
  </nav>
</header>

<MobileNav lang={lang} currentPath={currentPath} />

<!-- Scroll-aware header behavior -->
<script>
  (function () {
    const header = document.getElementById('site-header');
    const logoText = document.getElementById('header-logo-text');
    const hamburger = document.getElementById('hamburger-icon');
    const phone = document.getElementById('header-phone');
    if (!header) return;

    const isTransparent = header.dataset.transparent === 'true';
    if (!isTransparent) return;

    const observer = new IntersectionObserver(
      ([entry]) => {
        const scrolled = !entry.isIntersecting;
        if (scrolled) {
          header.classList.remove('bg-transparent');
          header.classList.add(
            'bg-surface/70',
            'backdrop-blur-xl',
            'shadow-[0_24px_48px_-12px_rgba(139,26,107,0.08)]'
          );
          header.querySelectorAll('[data-nav-link]').forEach((el) => {
            el.classList.remove('text-white/80', 'text-white');
            el.classList.add('text-muted');
          });
          if (logoText) {
            logoText.classList.remove('text-white');
            logoText.classList.add('text-primary');
          }
          if (hamburger) {
            hamburger.classList.remove('text-white');
            hamburger.classList.add('text-dark');
          }
          if (phone) {
            phone.classList.remove('text-white/80');
            phone.classList.add('text-muted');
          }
        } else {
          header.classList.add('bg-transparent');
          header.classList.remove(
            'bg-surface/70',
            'backdrop-blur-xl',
            'shadow-[0_24px_48px_-12px_rgba(139,26,107,0.08)]'
          );
          header.querySelectorAll('[data-nav-link]').forEach((el) => {
            el.classList.add('text-white/80');
            el.classList.remove('text-muted');
          });
          if (logoText) {
            logoText.classList.add('text-white');
            logoText.classList.remove('text-primary');
          }
          if (hamburger) {
            hamburger.classList.add('text-white');
            hamburger.classList.remove('text-dark');
          }
          if (phone) {
            phone.classList.add('text-white/80');
            phone.classList.remove('text-muted');
          }
        }
      },
      { threshold: 0 }
    );

    const sentinel = document.getElementById('header-sentinel');
    if (sentinel) observer.observe(sentinel);
  })();
</script>
