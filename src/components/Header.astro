---
import type { Lang } from '../i18n/languages';
import { useTranslation } from '../i18n/utils';
import { mainNav } from '../data/navigation';
import LanguageSwitcher from './LanguageSwitcher.astro';
import MobileNav from './MobileNav.astro';
import { getWhatsAppUrl } from '../data/siteConfig';

interface Props {
  lang: Lang;
  currentPath: string;
  transparent?: boolean;
}

const { lang, currentPath, transparent = false } = Astro.props;
const t = useTranslation(lang);
---

<header
  id="site-header"
  class:list={[
    'fixed top-0 w-full z-50 transition-all duration-300',
    transparent
      ? 'bg-transparent'
      : 'bg-surface-container-lowest/80 backdrop-blur-md shadow-sm border-b border-outline-variant/10',
  ]}
  data-transparent={transparent ? 'true' : 'false'}
>
  <nav class="flex justify-between items-center px-6 md:px-8 py-4 max-w-7xl mx-auto" aria-label="Main navigation">
    <!-- Logo -->
    <a href={`/${lang}/`} class="flex items-center gap-2 flex-shrink-0">
      <img src="/images/logos/logo-icon.png" alt="Dany's Bees" width="40" height="40" class="h-10 w-10 rounded-lg object-cover" />
      <span class:list={[
        'font-serif italic text-xl font-bold hidden sm:inline',
        transparent ? 'text-white' : 'text-primary',
      ]} id="header-logo-text">
        Dany's Bees
      </span>
    </a>

    <!-- Desktop nav links -->
    <div class="hidden lg:flex items-center gap-8">
      {mainNav.map((item) => {
        const href = item.href(lang);
        const isActive = currentPath === href || (href !== `/${lang}/` && currentPath.startsWith(href.replace(/\/$/, '')));
        return (
          <a
            href={href}
            class:list={[
              'font-serif text-lg tracking-tight pb-1 transition-colors border-b-2',
              isActive
                ? (transparent ? 'text-white border-white' : 'text-primary border-primary')
                : (transparent ? 'text-white/80 border-transparent hover:text-white' : 'text-muted border-transparent hover:text-primary'),
            ]}
          >
            {t(item.key)}
          </a>
        );
      })}
    </div>

    <!-- Right side: language + CTA + hamburger -->
    <div class="flex items-center gap-4">
      <div class:list={['hidden md:block', transparent ? '[&_a]:text-white/80 [&_a]:hover:text-white [&_span]:text-white/40' : '']}>
        <LanguageSwitcher currentLang={lang} currentPath={currentPath} />
      </div>

      <a
        href={getWhatsAppUrl(lang === 'ar' ? 'مرحبا!' : lang === 'fr' ? 'Bonjour!' : 'Hi!')}
        target="_blank"
        rel="noopener noreferrer"
        class="hidden md:inline-flex honey-gradient text-white px-6 py-2.5 rounded-lg font-medium shadow-md hover:scale-95 transition-transform duration-200 items-center gap-2"
      >
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        {t('common.order_now')}
      </a>

      <!-- Hamburger (mobile) -->
      <button
        id="mobile-nav-open"
        class="lg:hidden p-2 rounded-lg transition-colors hover:bg-surface-container-low"
        aria-label="Open navigation menu"
      >
        <svg class:list={['w-6 h-6', transparent ? 'text-white' : 'text-dark']} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" id="hamburger-icon">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
        </svg>
      </button>
    </div>
  </nav>
</header>

<MobileNav lang={lang} currentPath={currentPath} />

<!-- Scroll-aware header behavior -->
<script>
  (function() {
  const header = document.getElementById('site-header');
  const logoText = document.getElementById('header-logo-text');
  const hamburger = document.getElementById('hamburger-icon');
  if (!header) return;

  const isTransparent = header.dataset.transparent === 'true';
  if (!isTransparent) return;

  const observer = new IntersectionObserver(
    ([entry]) => {
      const scrolled = !entry.isIntersecting;
      if (scrolled) {
        header.classList.remove('bg-transparent');
        header.classList.add('bg-surface-container-lowest/80', 'backdrop-blur-md', 'shadow-sm', 'border-b', 'border-outline-variant/10');
        header.querySelectorAll('.font-serif.text-lg').forEach((el) => {
          el.classList.remove('text-white/80', 'text-white');
          el.classList.add('text-muted');
        });
        if (logoText) {
          logoText.classList.remove('text-white');
          logoText.classList.add('text-primary');
        }
        if (hamburger) {
          hamburger.classList.remove('text-white');
          hamburger.classList.add('text-dark');
        }
      } else {
        header.classList.add('bg-transparent');
        header.classList.remove('bg-surface-container-lowest/80', 'backdrop-blur-md', 'shadow-sm', 'border-b', 'border-outline-variant/10');
        header.querySelectorAll('.font-serif.text-lg').forEach((el) => {
          el.classList.add('text-white/80');
          el.classList.remove('text-muted');
        });
        if (logoText) {
          logoText.classList.add('text-white');
          logoText.classList.remove('text-primary');
        }
        if (hamburger) {
          hamburger.classList.add('text-white');
          hamburger.classList.remove('text-dark');
        }
      }
    },
    { threshold: 0 }
  );

  // Observe a sentinel element just below the hero
  const sentinel = document.getElementById('header-sentinel');
  if (sentinel) observer.observe(sentinel);
  })();
</script>
