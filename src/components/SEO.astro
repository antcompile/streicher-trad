---
import type { Lang } from '../i18n/languages';
import { supportedLangs } from '../i18n/languages';
import { siteConfig } from '../data/siteConfig';

interface Props {
  title: string;
  description: string;
  image?: string;
  lang: Lang;
  slug: string;
  type?: 'website' | 'article';
  jsonLd?: Record<string, any>;
}

const {
  title,
  description,
  image,
  lang,
  slug,
  type = 'website',
  jsonLd,
} = Astro.props;

const fullTitle = `${title} | Streicher Trad`;
const canonicalUrl = `${siteConfig.url}/${lang}/${slug}`.replace(/\/+$/, '/');
const imageUrl = image ? (image.startsWith('http') ? image : `${siteConfig.url}${image}`) : undefined;

const localeMap: Record<string, string> = {
  en: 'en_US',
  fr: 'fr_FR',
};
---

<title>{fullTitle}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonicalUrl} />

<!-- Open Graph -->
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
{imageUrl && <meta property="og:image" content={imageUrl} />}
<meta property="og:url" content={canonicalUrl} />
<meta property="og:type" content={type === 'article' ? 'article' : 'website'} />
<meta property="og:locale" content={localeMap[lang] || 'fr_FR'} />
<meta property="og:site_name" content="Streicher Trad" />

<!-- hreflang alternates -->
{supportedLangs.map((l) => (
  <link
    rel="alternate"
    hreflang={l}
    href={`${siteConfig.url}/${l}/${slug}`.replace(/\/+$/, '/')}
  />
))}
<link rel="alternate" hreflang="x-default" href={`${siteConfig.url}/fr/${slug}`.replace(/\/+$/, '/')} />

<!-- JSON-LD -->
{jsonLd && (
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
)}
