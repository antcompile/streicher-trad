---
import type { Lang } from '../i18n/languages';
import { useTranslation, getLocalizedContent, getLocalizedArray } from '../i18n/utils';

interface Props {
  tour: {
    id: string;
    data: {
      id: string;
      name: Record<string, string>;
      tagline: Record<string, string>;
      price_display: Record<string, string>;
      price_usd: number;
      duration: string;
      max_group: number;
      availability: Record<string, string>;
      includes: Record<string, string[]>;
      description: Record<string, string>;
      image: string;
      badge: string | null;
    };
  };
  lang: Lang;
  featured?: boolean;
}

const { tour, lang, featured = false } = Astro.props;
const t = useTranslation(lang);
const d = tour.data;

const name = getLocalizedContent(d.name, lang);
const tagline = getLocalizedContent(d.tagline, lang);
const price = getLocalizedContent(d.price_display, lang);
const availability = getLocalizedContent(d.availability, lang);
const includes = getLocalizedArray(d.includes, lang);

const badgeLabels: Record<string, Record<string, string>> = {
  'limited-season': {
    en: 'Limited, by season only',
    ar: 'محدود، موسمي فقط',
    fr: 'Limité, saisonnier uniquement',
  },
};
const badgeText = d.badge ? (badgeLabels[d.badge]?.[lang] || d.badge) : null;
---

<div class:list={[
  'bg-surface-container-lowest rounded-xl p-8 flex flex-col transition-all hover:scale-[1.02] relative',
  featured ? 'border-2 border-primary-container/30 shadow-lg' : 'border border-outline-variant/15',
]}>
  {badgeText && (
    <span class="absolute -top-4 start-1/2 -translate-x-1/2 bg-primary-container text-white px-4 py-1 rounded-full text-xs font-bold uppercase tracking-wider whitespace-nowrap shadow-md">
      {badgeText}
    </span>
  )}

  <div class="flex justify-between items-start mb-6">
    <div>
      <h3 class="text-2xl font-serif font-bold text-primary mb-2">{name}</h3>
      <p class="text-secondary font-medium italic">{tagline}</p>
    </div>
    <div class="text-end flex-shrink-0 ms-4">
      <span class="text-3xl font-bold text-dark">${d.price_usd}</span>
      <p class="text-sm text-muted">{t('tours.duration')}: {d.duration}</p>
    </div>
  </div>

  <div class="grid grid-cols-2 gap-4 mb-6 text-sm text-muted">
    <div class="flex items-center gap-2">
      <svg class="w-5 h-5 text-secondary flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" />
      </svg>
      <span>{availability}</span>
    </div>
    <div class="flex items-center gap-2">
      <svg class="w-5 h-5 text-secondary flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z" />
      </svg>
      <span>{t('tours.max_group')}: {d.max_group} {t('tours.persons')}</span>
    </div>
  </div>

  <div class="mb-8 flex-grow">
    <h4 class="font-bold text-sm uppercase tracking-widest text-secondary mb-4">{t('tours.includes')}</h4>
    <ul class="space-y-3">
      {includes.map((item) => (
        <li class="flex items-start gap-3 text-sm text-dark">
          <svg class="w-5 h-5 text-secondary flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z" />
          </svg>
          <span>{item}</span>
        </li>
      ))}
    </ul>
  </div>

  <a
    href="#booking"
    class:list={[
      'text-center font-bold py-4 rounded-xl transition-all uppercase tracking-widest text-sm',
      featured
        ? 'honey-gradient text-white shadow-lg'
        : 'bg-surface-container-high text-primary hover:bg-primary hover:text-white',
    ]}
  >
    {t('tours.book_this')}
  </a>
</div>
