---
import type { Lang } from '../i18n/languages';
import { getLocalizedContent } from '../i18n/utils';

interface Props {
  testimonial: {
    data: {
      name: string;
      location: Record<string, string>;
      quote: Record<string, string>;
      rating: number;
    };
  };
  lang: Lang;
}

const { testimonial, lang } = Astro.props;
const d = testimonial.data;
const quote = getLocalizedContent(d.quote, lang);
const location = getLocalizedContent(d.location, lang);
---

<div class="space-y-6">
  <div class="flex gap-1 text-primary-container">
    {Array.from({ length: d.rating }).map(() => (
      <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
      </svg>
    ))}
  </div>

  <blockquote class="font-serif text-lg md:text-xl italic text-dark leading-relaxed">
    "{quote}"
  </blockquote>

  <cite class="block text-on-surface-variant font-medium not-italic">
    — {d.name}, {location}
  </cite>
</div>
