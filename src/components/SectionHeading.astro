---
interface Props {
  label?: string;
  title: string;
  subtitle?: string;
  centered?: boolean;
}

const { label, title, subtitle, centered = true } = Astro.props;
---

<div class={centered ? 'text-center mb-16' : 'mb-16'}>
  {label && (
    <span class="block text-xs uppercase tracking-widest text-primary font-bold mb-3 font-body">
      {label}
    </span>
  )}
  <h2 class="font-headline font-black text-3xl sm:text-4xl md:text-5xl tracking-tighter text-dark mb-4">
    {title}
  </h2>
  {subtitle && (
    <p class={`text-on-surface-variant text-lg max-w-2xl leading-relaxed font-body ${centered ? 'mx-auto' : ''}`}>
      {subtitle}
    </p>
  )}
</div>
