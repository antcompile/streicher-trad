---
interface Props {
  title: string;
  subtitle?: string;
  centered?: boolean;
  italic?: boolean;
}

const { title, subtitle, centered = true, italic = true } = Astro.props;
---

<div class={centered ? 'text-center mb-16' : 'mb-16'}>
  <h2 class:list={[
    'font-serif text-3xl sm:text-4xl md:text-5xl text-primary tracking-tight mb-4',
    { 'italic': italic },
  ]}>
    {title}
  </h2>
  {subtitle && (
    <p class={`text-on-surface-variant text-lg max-w-2xl leading-relaxed ${centered ? 'mx-auto' : ''}`}>
      {subtitle}
    </p>
  )}
  <div class={`w-24 h-1 bg-primary-container rounded-full mt-6 ${centered ? 'mx-auto' : ''}`}></div>
</div>
