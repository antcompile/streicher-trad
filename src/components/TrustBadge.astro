---
interface Props {
  text: string;
  icon: string;
}

const { text, icon } = Astro.props;
---

<div class="flex flex-col items-center text-center gap-3 p-4">
  <div class="hexagon-mask w-14 h-16 bg-primary flex items-center justify-center text-white flex-shrink-0">
    <Fragment set:html={icon} />
  </div>
  <p class="font-serif text-dark font-semibold text-sm leading-snug">{text}</p>
</div>
