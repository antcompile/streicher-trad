---
import type { Lang } from '../i18n/languages';
import { useTranslation } from '../i18n/utils';
import { siteConfig } from '../data/siteConfig';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslation(lang);
---

<section class="bg-surface-container-high rounded-3xl overflow-hidden shadow-xl grid md:grid-cols-2" id="booking">
  <div class="p-8 md:p-12 space-y-8">
    <h2 class="text-3xl md:text-4xl font-serif text-primary">{t('tours.book_now')}</h2>

    <form action={siteConfig.formspreeBooking} method="POST" class="space-y-6" id="booking-form">
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
        <div class="space-y-1">
          <label class="form-label" for="booking-name">{t('booking.name')}</label>
          <input id="booking-name" name="name" type="text" required class="form-input" dir="auto" />
        </div>
        <div class="space-y-1">
          <label class="form-label" for="booking-email">{t('booking.email')}</label>
          <input id="booking-email" name="email" type="email" required class="form-input" dir="ltr" />
        </div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
        <div class="space-y-1">
          <label class="form-label" for="booking-phone">{t('booking.phone')}</label>
          <input id="booking-phone" name="phone" type="tel" class="form-input" dir="ltr" />
        </div>
        <div class="space-y-1">
          <label class="form-label" for="booking-date">{t('booking.date')}</label>
          <input id="booking-date" name="date" type="date" required class="form-input" />
        </div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
        <div class="space-y-1">
          <label class="form-label" for="booking-group">{t('booking.group_size')}</label>
          <select id="booking-group" name="group_size" required class="form-input">
            {Array.from({ length: 20 }, (_, i) => i + 1).map((n) => (
              <option value={n}>{n}</option>
            ))}
          </select>
        </div>
        <div class="space-y-1">
          <label class="form-label" for="booking-tour">{t('booking.tour_type')}</label>
          <select id="booking-tour" name="tour_type" required class="form-input">
            <option value="standard">Honey & Hive Experience</option>
            <option value="premium">Honey Harvest Experience</option>
          </select>
        </div>
      </div>

      <div class="space-y-1">
        <label class="form-label" for="booking-message">{t('booking.message')}</label>
        <textarea id="booking-message" name="message" rows="3" class="form-input" dir="auto"></textarea>
      </div>

      <button
        type="submit"
        class="w-full bg-primary text-white py-4 rounded-xl font-bold shadow-lg hover:bg-primary/90 transition-colors uppercase tracking-widest text-sm"
      >
        {t('booking.submit')}
      </button>

      <div id="booking-success" class="hidden text-center py-4 text-success font-medium">
        {t('booking.success')}
      </div>
    </form>

    <div class="text-center pt-4 border-t border-outline-variant/15">
      <p class="text-muted text-sm">
        {t('booking.prefer_call')}
        <a href={`tel:${siteConfig.phoneRaw}`} class="text-primary font-medium hover:underline ms-1" dir="ltr">
          {siteConfig.phone}
        </a>
      </p>
    </div>
  </div>

  <div class="relative hidden md:block">
    <img
      src="/images/tours/standard-tour.jpg"
      alt=""
      class="w-full h-full object-cover"
      loading="lazy"
    />
    <div class="absolute inset-0 bg-primary/20 mix-blend-overlay"></div>
  </div>
</section>

<script>
  const form = document.getElementById('booking-form') as HTMLFormElement;
  const success = document.getElementById('booking-success');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    try {
      const response = await fetch(form.action, {
        method: 'POST',
        body: new FormData(form),
        headers: { Accept: 'application/json' },
      });
      if (response.ok) {
        form.reset();
        if (success) success.classList.remove('hidden');
      }
    } catch {
      // Silently fail; form still works without JS via standard submission
    }
  });
</script>
